{
	"langrev": "1",
	"warnings": ["no-unused", "no-deprecated"],
	"authors": [],
	"version": "0.1.0",
	"dependency-search-paths": [ "./dependencies", "./lib"],
	"dependencies": ["c3w", "vk", "xr"],
	"features": ["WAYLAND"],
	"sources": ["./src"],
	"script-dir": "./",
	"targets": {
		"shaders": {
			"type": "prepare",
			"exec": [
				"slangc ./shaders/main.slang -force-glsl-scalar-layout -fvk-use-entrypoint-name -target spirv -emit-spirv-directly -o ./shaders/main.spv"
			]
		},
		"stream": {
			"type": "executable",
			"linked-libraries": ["vulkan"],
			"linker-search-paths": ["./"],
			"linked-libraries-local": ["openxr_loader"],
			"sources": ["./src/main.c3", "./src/openxr_context.c3", "./src/vulkan_context.c3"]
		}
	},
	"output": "./build"
}